# ─── BboxPulse Configuration ───
# Copier ce fichier en .env et remplir les valeurs

# Mot de passe de la BBox
BBOX_PASSWORD=your_bbox_password_here

# URL de la BBox (ne pas modifier sauf cas particulier)
BBOX_BASE_URL=https://mabbox.bytel.fr

# Redis
REDIS_URL=redis://redis:6379/0

# Port de l'application
APP_PORT=5000

# Intervalle de collecte en secondes (background monitor)
MONITOR_INTERVAL=60

# Date de début d'infrastructure (format: YYYY-MM-DD)
UPTIME_START_DATE=2026-05-18

# Objectif cible en To
TARGET_TB=5
